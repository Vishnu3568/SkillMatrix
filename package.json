{
  "name": "skillmatrix-root",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "lint:server": "npm run lint --prefix server",
    "lint:client": "npm run lint --prefix client",
    "lint": "npm run lint:server && npm run lint:client",
    "format:server": "npm run format --prefix server",
    "format:client": "npm run format --prefix client",
    "format": "npm run format:server && npm run format:client",
    "build:server": "npm run build --prefix server",
    "build:client": "npm run build --prefix client",
    "build": "npm run build:server && npm run build:client"
  },
  "devDependencies": {
    "prettier": "^3.2.5"
  }
}
