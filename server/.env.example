# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection
MONGODB_URI=mongodb://localhost:27017/skillmatrix

# JWT Secret Tokens (Use strong random strings in production)
JWT_ACCESS_SECRET=access_token_secret_placeholder_change_me
JWT_REFRESH_SECRET=refresh_token_secret_placeholder_change_me

# CORS Configuration
CLIENT_URL=http://localhost:5173

# Cloudinary Integration (Future Asset Storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Security & Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
